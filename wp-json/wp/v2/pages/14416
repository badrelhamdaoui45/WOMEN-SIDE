nt\/uploads\/2026\/02\/campagne-ne-pas-ignorer-217x300.webp 217w, https:\/\/fondationdesfemmes.org\/wp-content\/uploads\/2026\/02\/campagne-ne-pas-ignorer-768x1060.webp 768w, https:\/\/fondationdesfemmes.org\/wp-content\/uploads\/2026\/02\/campagne-ne-pas-ignorer.webp 1040w\" sizes=\"(max-width: 742px) 100vw, 742px\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-82f7bd7 e-con-full e-flex e-con e-child\" data-id=\"82f7bd7\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t<div class=\"elementor-element elementor-element-0f5afb3 e-con-full e-flex e-con e-child\" data-id=\"0f5afb3\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-a64c11c elementor-widget elementor-widget-heading\" data-id=\"a64c11c\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Ne pas ignorer<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-a05d261 elementor-widget elementor-widget-heading\" data-id=\"a05d261\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h3 class=\"elementor-heading-title elementor-size-default\">25 novembre 2024<\/h3>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-26bdba2 elementor-widget elementor-widget-text-editor\" data-id=\"26bdba2\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\t<p>Port\u00e9e par le message \u00ab Face \u00e0 l\u2019indiff\u00e9rence, vos dons font la diff\u00e9rence \u00bb, la campagne #NePasIgnorer met en lumi\u00e8re les cons\u00e9quences de l\u2019inaction face aux violences sexuelles et conjugales. Elle s\u2019appuie sur les t\u00e9moignages de Diariata N\u2019Diaye, de la chanteuse Mathilde et de Caroline Darian, fille de Gis\u00e8le Pelicot, pour d\u00e9noncer les classements sans suite, le non-accueil des plaintes et le silence institutionnel.\u200b<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-3bbe1b7 elementor-widget elementor-widget-button\" data-id=\"3bbe1b7\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"button.default\">\n\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-button elementor-button-link elementor-size-sm\" href=\"#\">\n\t\t\t\t\t\t<span class=\"elementor-button-content-wrapper\">\n\t\t\t\t\t\t\t\t\t<span class=\"elementor-button-text\">Voir la campagne<\/span>\n\t\t\t\t\t<\/span>\n\t\t\t\t\t<\/a>\n\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-01d3fd4 e-flex e-con-boxed e-con e-parent\" data-id=\"01d3fd4\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t<div class=\"elementor-element elementor-element-166cc60 e-con-full e-flex e-con e-child\" data-id=\"166cc60\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t<div class=\"elementor-element elementor-element-e3fc78d e-con-full e-flex e-con e-child\" data-id=\"e3fc78d\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-c5faf26 text-pretty elementor-widget elementor-widget-heading\" data-id=\"c5faf26\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Un <span class=\"highlight-jaune\">engagement<\/span> renforc\u00e9 autour du 8 mars et du 25 novembre<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-4a43fba elementor-widget elementor-widget-text-editor\" data-id=\"4a43fba\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\t<p>La Fondation des Femmes fait du 8 mars et du 25 novembre deux temps forts de mobilisation nationale autour des droits des femmes.<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-bcfee3f e-con-full e-grid e-con e-child\" data-id=\"bcfee3f\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t<div class=\"elementor-element elementor-element-a9ad09a e-con-full e-flex e-con e-child\" data-id=\"a9ad09a\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t\t<div class=\"elementor-element elementor-element-54b244c elementor-widget elementor-widget-heading\" data-id=\"54b244c\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h3 class=\"elementor-heading-title elementor-size-default\">Le 8 mars<\/h3>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-40f13cb elementor-widget elementor-widget-text-editor\" data-id=\"40f13cb\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\t<p>met en lumi\u00e8re les in\u00e9galit\u00e9s persistantes (\u00e9conomiques, politiques, sociales) et la force des mouvements f\u00e9ministes, \u00e0 travers des campagnes de communication, des prises de parole publiques et des appels \u00e0 dons pour financer les associations de terrain.<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-fa6ed78 elementor-hidden-mobile elementor-widget elementor-widget-button\" data-id=\"fa6ed78\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"button.default\">\n\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-button elementor-button-link elementor-size-sm\" href=\"#\">\n\t\t\t\t\t\t<span class=\"elementor-button-content-wrapper\">\n\t\t\t\t\t\t\t\t\t<