darit\u00e9, permettant de partager nos actions et leur impact avec le plus grand nombre, gr\u00e2ce aux marques partenaires, aux \u00e9quipes de la Fondation des Femmes, \u00e0 la Cit\u00e9 Audacieuse et \u00e0 nos formidables b\u00e9n\u00e9voles. MERCI \ud83d\ude42\u00a0\u00bb<\/p>\n\t\t\t\t\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-18949a7 e-con-full e-flex e-con e-child\" data-id=\"18949a7\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-7a413be elementor-widget__width-initial elementor-widget elementor-widget-image\" data-id=\"7a413be\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<a href=\"https:\/\/fondationdesfemmes.org\/temoignage\/alexane\/\">\n\t\t\t\t\t\t\t<img decoding=\"async\" width=\"789\" height=\"1024\" src=\"https:\/\/fondationdesfemmes.org\/wp-content\/uploads\/2026\/02\/Alexane-referente-pole-collecte-789x1024.jpg\" class=\"attachment-large size-large wp-image-45614\" alt=\"\" srcset=\"https:\/\/fondationdesfemmes.org\/wp-content\/uploads\/2026\/02\/Alexane-referente-pole-collecte-789x1024.jpg 789w, https:\/\/fondationdesfemmes.org\/wp-content\/uploads\/2026\/02\/Alexane-referente-pole-collecte-231x300.jpg 231w, https:\/\/fondationdesfemmes.org\/wp-content\/uploads\/2026\/02\/Alexane-referente-pole-collecte-768x996.jpg 768w, https:\/\/fondationdesfemmes.org\/wp-content\/uploads\/2026\/02\/Alexane-referente-pole-collecte.jpg 800w\" sizes=\"(max-width: 789px) 100vw, 789px\" \/>\t\t\t\t\t\t\t\t<\/a>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-d057f32 e-con-full e-flex e-con e-child\" data-id=\"d057f32\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-1523b5c elementor-widget elementor-widget-heading\" data-id=\"1523b5c\" data-element_type=\"widget\" data-e-type=\